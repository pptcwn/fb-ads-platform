# ─── Database ───
DB_PASSWORD=dev_password_changeme
DATABASE_URL=postgresql://postgres:***@postgres:5432/fb_ads_platform

# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── JWT ───
JWT_SECRET=change-me-to-a-random-256-bit-string
# Auth token is set in httpOnly cookie `fb_ads_token` (Bearer header still supported)

# ─── Object storage (Cloudflare R2 / S3) — creatives uploads ───
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_BUCKET=fb-ads-creatives
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://cdn.example.com
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true

# ─── Facebook App ───
# 1. Go to https://developers.facebook.com → My Apps → Create App (Business)
# 2. Add "Facebook Login" product, configure OAuth redirect URIs
# 3. Valid OAuth Redirect URI ต้องตรงกับด้านล่างเป๊ะ (รวม trailing slash?)
#    Dev: http://localhost:4001/api/facebook/callback
#    Prod: https://fb-ads.minstance.cloud/api/facebook/callback
#
# 4. Scopes ที่ต้องขอ: ads_management, ads_read, business_management, email
FB_APP_ID=your_fb_app_id
FB_APP_SECRET=your_fb_app_secret
FB_REDIRECT_URI=http://localhost:4001/api/facebook/callback
FB_API_VERSION=v24.0
# FB_API_MAX_RETRIES=4
# FB_API_RETRY_BASE_MS=1000

# ─── Encryption ───
TOKEN_ENCRYPTION_KEY=32-byte-hex-string-here-change-me

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:4001

# ─── FB API rate limit (per ad account, Redis) ───
# FB_API_RATE_LIMIT_ENABLED=true
# FB_API_MAX_CALLS_PER_ACCOUNT_SEC=8

# ─── Automation guardrails ───
# AUTOMATION_GUARDRAILS_ENABLED=true
# BUDGET_MAX_DAILY_CAP=5000
# BUDGET_MAX_INCREASE_PERCENT=50
# BUDGET_APPROVAL_THRESHOLD=1500

# ─── Meta webhooks (mTLS) ───
# META_WEBHOOK_VERIFY_TOKEN=change-me
# META_WEBHOOK_MTLS_REQUIRED=false
# META_CA_BUNDLE_PATH=/path/to/meta-ca-bundle.pem

# ─── Auto sync (BullMQ — no manual Sync Now required) ───
# SYNC_CAMPAIGNS_INTERVAL_MS=900000
# SYNC_INSIGHTS_INTERVAL_MS=3600000
# SYNC_INSIGHTS_30D_INTERVAL_MS=21600000

# ─── Reconcile / Alerts ───
# RECONCILE_TELEGRAM_NOTIFY=true

# ─── Insights (async report runs for large queries) ───
# INSIGHTS_ASYNC_POLL_MS=2000
# INSIGHTS_ASYNC_MAX_POLLS=90

# ─── Monitoring (change before production) ───
GRAFANA_PASSWORD=change-me-in-production
