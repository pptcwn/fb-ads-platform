FROM node:20-alpine AS base

RUN apk add --no-cache openssl

RUN corepack enable && corepack prepare pnpm@9.1.0 --activate

WORKDIR /app

# Copy workspace files
COPY package.json pnpm-workspace.yaml turbo.json ./
COPY pnpm-lock.yaml* ./

# Copy API package
COPY apps/api/package.json apps/api/
COPY packages/shared/package.json packages/shared/

# Install workspace deps (first pass from package manifests only)
RUN pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# Copy source and reinstall so new api deps (ioredis, cookie-parser, s3) land in the image
COPY . .
RUN pnpm install --frozen-lockfile 2>/dev/null || pnpm install

EXPOSE 4000

CMD cd apps/api && npx prisma generate && cd /app && pnpm --filter api start:dev
