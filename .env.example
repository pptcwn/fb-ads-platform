# ─── Database ───
DB_PASSWORD=dev_password_changeme
DATABASE_URL=postgresql://postgres:***@postgres:5432/fb_ads_platform

# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── JWT ───
JWT_SECRET=change-me-to-a-random-256-bit-string

# ─── Facebook App ───
# 1. Go to https://developers.facebook.com → My Apps → Create App (Business)
# 2. Add "Facebook Login" product, configure OAuth redirect URIs
# 3. Valid OAuth Redirect URI ต้องตรงกับด้านล่างเป๊ะ (รวม trailing slash?)
#    Dev: http://localhost:4001/api/facebook/callback
#    Prod: https://fb-ads.minstance.cloud/api/facebook/callback
#
# 4. Scopes ที่ต้องขอ: ads_management, ads_read, business_management, email
FB_APP_ID=your_fb_app_id
FB_APP_SECRET=your_fb_app_secret
FB_REDIRECT_URI=http://localhost:4001/api/facebook/callback
FB_API_VERSION=v24.0

# ─── Encryption ───
TOKEN_ENCRYPTION_KEY=32-byte-hex-string-here-change-me

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:4001

# ─── Monitoring ───
GRAFANA_PASSWORD=admin
